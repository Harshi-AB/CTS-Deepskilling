<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<!--
  hibernate.cfg.xml for the Annotation Configuration walkthrough
  (https://www.tutorialspoint.com/hibernate/hibernate_annotations.htm).

  Notice there is NO <mapping resource="Employee.hbm.xml"/> entry here -
  the object-relational mapping instead comes from the @Entity/@Table/
  @Id/@GeneratedValue/@Column annotations declared directly on Employee.java.
-->
<hibernate-configuration>

    <session-factory>

        <!-- Database connection settings -->
        <property name="connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="connection.url">jdbc:mysql://localhost:3306/hibernatelearn</property>
        <property name="connection.username">root</property>
        <property name="connection.password">root</property>

        <!-- SQL dialect -->
        <property name="dialect">org.hibernate.dialect.MySQL8Dialect</property>

        <!-- Echo all executed SQL to stdout -->
        <property name="show_sql">true</property>

        <!-- Create/update the schema automatically based on annotated classes -->
        <property name="hbm2ddl.auto">update</property>

    </session-factory>

</hibernate-configuration>
